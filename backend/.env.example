# ── Server ─────────────────────────────────────────────────────────────
PORT=5001

# ── MongoDB ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/esignature_module

# ── Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# ── Frontend (used by DocuSign return URLs) ───────────────────────────
FRONTEND_URL=http://localhost:5175

# ── DocuSign (optional; leave blank to run in local/demo mode) ────────
# When DOCUSIGN_INTEGRATION_KEY is set, the backend will create real envelopes
# on DocuSign via JWT auth. Without it, envelopes live only in this DB.
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_USER_ID=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_AUTH_SERVER=account-d.docusign.com
DOCUSIGN_PRIVATE_KEY_PATH=./keys/docusign_private.pem
DOCUSIGN_REDIRECT_URI=http://localhost:5175/docusign/callback
